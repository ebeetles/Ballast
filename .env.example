# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (SQLite path relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/ballast.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=primary
# IANA timezone used for task/calendar scheduling (e.g. America/Los_Angeles)
DEFAULT_USER_TIMEZONE=America/Los_Angeles

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Intent classification (fast, cheap)
ROUTER_MODEL=claude-haiku-4-5-20251001
# Cognitive loop + onboarding (needs full reasoning)
COGNITIVE_MODEL=claude-sonnet-4-5-20250929
# Lightweight reflection tasks
REFLECTION_MODEL=claude-haiku-4-5-20251001

# Security
API_KEY=
ADMIN_API_KEY=
